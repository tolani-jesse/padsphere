{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PadSphere",
  "version": "1.0.14",
  "identifier": "com.padsphere.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PadSphere",
        "width": 1000,
        "height": 620,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY1QkM3NTA3OEM3NjlGQjAKUldTd24zYU1CM1c4OVhPVDRaWHMvNDVWbjhDS3pubUNIUmN0RkdreklwZVorY09HS3RmVEVhbloK",
      "endpoints": [
        "https://github.com/tolani-jesse/padsphere/releases/latest/download/latest.json"
      ]
    }
  }
}
